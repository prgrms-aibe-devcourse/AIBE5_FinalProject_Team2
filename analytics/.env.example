# Alpha-Helix analytics service config
ANALYTICS_INTERNAL_TOKEN=dev-internal-token-change-me
PRICE_CACHE_TTL_MIN=60

# Polygon.io API Key (설정 시 yfinance 대신 Polygon 데이터 우선 사용)
# https://polygon.io/dashboard → API Keys
POLYGON_API_KEY=

# KIS(한국투자증권) 시장 데이터 수집용 앱 키 (국내주식 일봉)
# KIS OpenAPI 포털 → 앱 등록 → 앱 키/시크릿
# 거래 계좌 키와 별도로 "시장 데이터 전용" 앱을 등록해도 됩니다.
# 미설정 시 KIS 국내주식 수집 스킵 (Polygon/Binance는 정상 동작)
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443
